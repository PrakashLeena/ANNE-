MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/anne?retryWrites=true&w=majority
PORT=5000

# Firebase Admin SDK (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Gmail SMTP)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_TO=hello@anne.studio

# Admin UIDs (comma-separated Firebase UIDs to grant admin access)
ADMIN_UIDS=uid1,uid2
